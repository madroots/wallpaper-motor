#!/bin/bash
# =============================================================================
# AppRun — Wallpaper Motor AppImage Entrypoint
# =============================================================================

# Resolve the AppImage root directory
HERE="$(dirname "$(readlink -f "${0}")")"
export APPDIR="${HERE}"

# Force X11/XCB backend — required for XFCE/X11 desktop overlay compatibility
export QT_QPA_PLATFORM="${QT_QPA_PLATFORM:-xcb}"

# Ensure xwinwrap and other bundled binaries are in PATH
export PATH="${HERE}/usr/bin:${PATH}"

# Launch the application using the python-appimage bundled wrapper script
exec "${HERE}/usr/bin/python3.11" "${HERE}/usr/src/wallpaper_manager.py" "$@"
